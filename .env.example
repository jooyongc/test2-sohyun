# Copy this file to `.env.local` and fill in your real values there.
# `.env.local` is git-ignored; this template is committed as documentation.
# Do NOT put real secrets in this file.

# --- A. Frontend (Vite) — safe to ship to the browser (publishable only) ---
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- B. Server / admin secrets — never prefix with VITE_, never import in src/* ---
# Used only for local admin tasks (running schema.sql, CLI, Management API).
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-database-password
# Session pooler URI: Dashboard → Project Settings → Database → Connection string
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Personal access token (starts with sbp_): https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxx
# service_role secret: Dashboard → Project Settings → API  (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- C. (Optional) Admin login created in Supabase Auth → Users ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password

# --- D. Claude API — powers AI draft writing in the admin editor ---
# SERVER-SIDE ONLY. Never prefix with VITE_. Used by the Cloudflare Pages
# Function at functions/api/ai/*. For production, ALSO set this in
# Cloudflare Pages → Settings → Environment variables (same name).
# For local Functions dev with `wrangler pages dev`, put it in .dev.vars too.
# Create a key at: https://console.anthropic.com/settings/keys  (starts with sk-ant-)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
