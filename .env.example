# Supabase — copy this file to `.env.local` and fill in your project values.
# Find these in Supabase Dashboard → Project Settings → Data API / API Keys.
# Only the anon (publishable) key belongs in the frontend. NEVER put the
# service_role key here — security is enforced by Row Level Security (RLS).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
